<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>dima.sweep.jetbrains-plugin-local-sweep</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Local Sweep Tab Completion</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor>Dima</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Simple HTML elements (text formatting, paragraphs, and lists) can be added inside of <![CDATA[ ]]> tag.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description><![CDATA[
    Enter short description for your plugin here.<br>
    <em>most HTML tags may be used</em>
  ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
<!--
        <inline.completion.provider
            id="dima.sweep.SweepCompletionProvider"
            implementation="dima.sweep.SweepCompletionProvider"/>
-->
        <!-- <inline.completion.provider
            id="dima.sweep.GenericCompletionProvider"
            implementation="dima.sweep.GenericCompletionProvider"/> -->
        <!-- <inline.completion.provider
            id="dima.sweep.FimCompletionProvider"
            implementation="dima.sweep.FimCompletionProvider"/> -->
        <inline.completion.provider
            id="dima.sweep.localcomplete.LocalLineCompletionProvider"
            implementation="dima.sweep.localcomplete.provider.LocalLineCompletionProvider"/>
        <postStartupActivity
            implementation="dima.sweep.localcomplete.startup.LocalCompleteStartupActivity"/>
        <fileDocumentManagerListener
            implementation="dima.sweep.localcomplete.listener.FileSaveListener"/>
        <applicationConfigurable
            parentId="tools"
            instance="dima.sweep.localcomplete.settings.LocalCompleteConfigurable"
            id="dima.sweep.localcomplete.settings"
            displayName="Local Line Complete"/>
    </extensions>

    <applicationListeners>
        <listener class="dima.sweep.localcomplete.listener.FileDeleteListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
        <listener class="dima.sweep.localcomplete.listener.CompletionActionListener"
                  topic="com.intellij.openapi.actionSystem.ex.AnActionListener"/>
        <listener class="dima.sweep.localcomplete.listener.LocalCompleteShutdownListener"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <projectListeners>
        <listener class="dima.sweep.localcomplete.listener.FileOpenListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

